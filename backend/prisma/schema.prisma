// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// AUTH & USER MODELS
// =============================================================================

model User {
  id                 String     @id @default(cuid())
  username           String     @unique @db.VarChar(255)
  name               String     @db.VarChar(255)
  email              String     @unique @db.VarChar(255)
  password           String     @db.VarChar(255)
  isActive           Boolean    @default(false)
  isVerified         Boolean    @default(false)
  passwordChangedAt  DateTime?
  mustChangePassword Boolean    @default(false)
  totpSecret         String?    @db.VarChar(500)
  totpEnabled        Boolean    @default(false)
  totpVerifiedAt     DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  userRoles          UserRole[]
  session            Session?
  profile            Profile?

  @@index([email])
  @@index([username])
  @@index([isActive, isVerified])
  @@map("users")
}

model Role {
  id          String     @id @default(cuid())
  name        RoleName   @unique
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @db.VarChar(500)
  deviceId     String   @db.VarChar(255)
  deviceName   String?  @db.VarChar(255)
  userAgent    String?  @db.Text
  ipAddress    String?  @db.VarChar(45)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

// =============================================================================
// ORGANIZATION MODELS
// =============================================================================

model UnitKerja {
  id                String             @id @default(cuid())
  name              String             @db.VarChar(255)
  code              String             @unique @db.VarChar(100)
  email             String             @db.VarChar(255)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  profiles          Profile[]
  assets            Asset[]
  businessProcesses BusinessProcess[]
  workingPapers     WorkingPaper[]

  @@index([code])
  @@map("unit_kerja")
}

model Profile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jabatan     String    @db.VarChar(255)
  unitKerjaId String
  unitKerja   UnitKerja @relation(fields: [unitKerjaId], references: [id], onDelete: Restrict)
  nomorHP     String?   @db.VarChar(20)
  isVerified  Boolean   @default(false)
  verifiedAt  DateTime?
  verifiedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([unitKerjaId])
  @@index([isVerified])
  @@map("profiles")
}

// =============================================================================
// ASSET & PROCESS MODELS
// =============================================================================

model AssetCategory {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]

  @@map("asset_categories")
}

model Asset {
  id            String         @id @default(cuid())
  unitKerjaId   String
  unitKerja     UnitKerja      @relation(fields: [unitKerjaId], references: [id], onDelete: Restrict)
  categoryId    String
  category      AssetCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name          String         @db.VarChar(255)
  code          String         @db.VarChar(100)
  description   String?        @db.Text
  owner         String?        @db.VarChar(255)
  status        AssetStatus    @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?
  updatedBy     String?
  contextAssets ContextAsset[]
  riskEntries   RiskEntry[]

  @@unique([unitKerjaId, code])
  @@index([unitKerjaId])
  @@index([categoryId])
  @@index([status])
  @@map("assets")
}

model BusinessProcess {
  id               String           @id @default(cuid())
  unitKerjaId      String
  unitKerja        UnitKerja        @relation(fields: [unitKerjaId], references: [id], onDelete: Restrict)
  name             String           @db.VarChar(255)
  code             String           @db.VarChar(100)
  description      String?          @db.Text
  owner            String?          @db.VarChar(255)
  status           ProcessStatus    @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        String?
  updatedBy        String?
  contextProcesses ContextProcess[]
  riskEntries      RiskEntry[]

  @@unique([unitKerjaId, code])
  @@index([unitKerjaId])
  @@index([status])
  @@map("business_processes")
}

// =============================================================================
// RISK MANAGEMENT MODELS
// =============================================================================

/// Master daftar framework manajemen risiko yang tersedia di sistem.
/// Bersifat reusable — satu Framework dapat digunakan di banyak RiskProgram.
/// Contoh: ISO 31000, ISO 27005, SPBE, SPIP
model Framework {
  id                String             @id @default(cuid())
  code              String             @unique @db.VarChar(100)
  name              String             @db.VarChar(255)
  version           String?            @db.VarChar(50)
  description       String?            @db.Text
  isActive          Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  programFrameworks ProgramFramework[]
  riskContexts      RiskContext[]

  @@index([code])
  @@index([isActive])
  @@map("frameworks")
}

/// Program manajemen risiko tahunan institusi.
/// Satu program dapat menggunakan BANYAK framework sekaligus via ProgramFramework.
/// Contoh: "Manajemen Risiko Instansi 2026" → SPBE + SPIP + ISO 27001
model RiskProgram {
  id                String             @id @default(cuid())
  name              String             @db.VarChar(255)
  description       String?            @db.Text
  year              Int
  status            RiskProgramStatus  @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  updatedBy         String?
  programFrameworks ProgramFramework[]
  workingPapers     WorkingPaper[]

  @@index([year])
  @@index([status])
  @@map("risk_programs")
}

/// Join table antara RiskProgram dan Framework.
/// Menyimpan konfigurasi matrix spesifik per framework dalam satu program.
/// Contoh: Program 2026 + SPBE = matrix 5x5, Program 2026 + ISO = matrix 4x4
model ProgramFramework {
  id          String                 @id @default(cuid())
  programId   String
  program     RiskProgram            @relation(fields: [programId], references: [id], onDelete: Cascade)
  frameworkId String
  framework   Framework              @relation(fields: [frameworkId], references: [id], onDelete: Restrict)

  status       ProgramFrameworkStatus @default(ACTIVE)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  createdBy    String?
  updatedBy    String?
  programFrameworkContexts ProgramFrameworkContext[]

  /// Satu program tidak boleh mendaftarkan framework yang sama dua kali
  @@unique([programId, frameworkId])
  @@index([programId])
  @@index([frameworkId])
  @@index([status])
  @@map("program_frameworks")
}

/// Template konteks risiko yang dimiliki oleh Framework (global).
/// Contoh: SPBE context → "Infrastruktur Server", "Aplikasi Internal"
///         ISO 27001 context → "Information Asset", "Business Process"
model RiskContext {
  id                      String             @id @default(cuid())
  name                    String             @db.VarChar(255)
  /// Kode unik di dalam scope framework yang sama
  code                    String             @db.VarChar(100)
  description             String?            @db.Text

  frameworkId             String
  framework               Framework          @relation(fields: [frameworkId], references: [id], onDelete: Restrict)

  contextType             ContextType

  periodStart             Int
  periodEnd               Int

  matrixRows              Int
  matrixCols              Int

  isSystemDefault         Boolean            @default(false)

  riskAppetiteLevel       String?            @db.VarChar(100)
  riskAppetiteDescription String?            @db.Text

  status                  RiskContextStatus  @default(INACTIVE)

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  createdBy               String?
  updatedBy               String?

  riskCategories           RiskCategory[]
  impactAreas              ImpactArea[]
  likelihoodCriteria       LikelihoodCriteria[]
  treatmentOptions         TreatmentOption[]
  riskLevels               RiskLevel[]
  matrixCells              MatrixCell[]
  contextAssets            ContextAsset[]
  contextProcesses         ContextProcess[]
  programFrameworkContexts ProgramFrameworkContext[]

  /// Kode hanya unik dalam satu Framework
  @@unique([frameworkId, code])
  @@index([frameworkId])
  @@index([status])
  @@index([contextType])
  @@index([periodStart, periodEnd])
  @@map("risk_contexts")
}

model ProgramFrameworkContext {
  id                 String           @id @default(cuid())
  programFrameworkId String
  programFramework   ProgramFramework @relation(fields: [programFrameworkId], references: [id], onDelete: Cascade)
  riskContextId      String
  riskContext        RiskContext      @relation(fields: [riskContextId], references: [id], onDelete: Restrict)
  addedAt            DateTime         @default(now())
  addedBy            String?

  riskEntries        RiskEntry[]

  @@unique([programFrameworkId, riskContextId])
  @@index([programFrameworkId])
  @@index([riskContextId])
  @@map("program_framework_contexts")
}

model ContextAsset {
  id        String      @id @default(cuid())
  contextId String
  context   RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([contextId, assetId])
  @@index([contextId])
  @@index([assetId])
  @@map("context_assets")
}

/// Kategori/jenis risiko dalam konteks (misal: Risiko Operasional, Risiko Keuangan)
model RiskCategory {
  id          String      @id @default(cuid())
  contextId   String
  context     RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name        String      @db.VarChar(255)
  description String?     @db.Text
  color       String?     @db.VarChar(7)
  code        String?     @db.VarChar(50)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  riskEntries RiskEntry[]

  @@index([contextId])
  @@map("risk_categories")
}

/// Area dampak dalam konteks (misal: Keuangan, Reputasi, Operasional)
model ImpactArea {
  id                 String               @id @default(cuid())
  contextId          String
  context            RiskContext          @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name               String               @db.VarChar(255)
  description        String?              @db.Text
  order              Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  impactCriteria     ImpactCriteria[]
  likelihoodCriteria LikelihoodCriteria[]
  areaScores         AreaScore[]
  treatmentPlans     RiskTreatmentPlan[]

  @@index([contextId])
  @@map("impact_areas")
}

/// Kriteria dampak per area per level/kolom (level 1..matrixCols)
model ImpactCriteria {
  id           String     @id @default(cuid())
  impactAreaId String
  impactArea   ImpactArea @relation(fields: [impactAreaId], references: [id], onDelete: Cascade)
  level        Int
  name         String     @db.VarChar(255)
  description  String?    @db.Text
  score        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([impactAreaId, level])
  @@index([impactAreaId])
  @@map("impact_criteria")
}

/// Kriteria kemungkinan per level/baris per area dampak (level 1..matrixRows)
/// Setiap ImpactArea memiliki kriteria kemungkinannya sendiri.
model LikelihoodCriteria {
  id           String     @id @default(cuid())
  contextId    String
  context      RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  impactAreaId String
  impactArea   ImpactArea @relation(fields: [impactAreaId], references: [id], onDelete: Cascade)
  level        Int
  name         String     @db.VarChar(255)
  description  String?    @db.Text
  score        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([impactAreaId, level])
  @@index([contextId])
  @@index([impactAreaId])
  @@map("likelihood_criteria")
}

/// Opsi penanganan risiko (Mitigasi, Transfer, Terima, Hindari, dll)
model TreatmentOption {
  id            String      @id @default(cuid())
  contextId     String
  context       RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name          String      @db.VarChar(255)
  description   String?     @db.Text
  isAcceptance  Boolean     @default(false)
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  treatmentPlans RiskTreatmentPlan[]

  @@index([contextId])
  @@map("treatment_options")
}

/// Level/peringkat risiko dalam konteks (misal: Rendah, Sedang, Tinggi, Kritikal).
/// Setiap level memiliki rentang skor yang dipetakan ke nilai MatrixCell.
model RiskLevel {
  id          String      @id @default(cuid())
  contextId   String
  context     RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  name        String      @db.VarChar(100)
  description String?     @db.Text
  minScore    Int
  maxScore    Int
  color       String?     @db.VarChar(7)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  riskAssessments RiskAssessment[]

  /// Urutan dan nama harus unik per konteks
  @@unique([contextId, order])
  @@unique([contextId, name])
  @@index([contextId])
  @@map("risk_levels")
}

/// Nilai setiap cell dalam matriks risiko (row=likelihood level, col=impact level)
model MatrixCell {
  id        String      @id @default(cuid())
  contextId String
  context   RiskContext @relation(fields: [contextId], references: [id], onDelete: Cascade)
  row       Int
  col       Int
  value     Int
  label     String?     @db.VarChar(100)
  color     String?     @db.VarChar(7)

  areaScores AreaScore[]

  @@unique([contextId, row, col])
  @@index([contextId])
  @@map("matrix_cells")
}

model ContextProcess {
  id        String          @id @default(cuid())
  contextId String
  context   RiskContext     @relation(fields: [contextId], references: [id], onDelete: Cascade)
  processId String
  process   BusinessProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([contextId, processId])
  @@index([contextId])
  @@index([processId])
  @@map("context_processes")
}

// =============================================================================
// KERTAS KERJA MODELS
// =============================================================================

/// Satu kertas kerja per Unit Kerja per Program.
/// Menampung semua risiko lintas framework dalam satu dokumen.
model WorkingPaper {
  id          String             @id @default(cuid())
  programId   String
  program     RiskProgram        @relation(fields: [programId], references: [id], onDelete: Restrict)
  unitKerjaId String
  unitKerja   UnitKerja          @relation(fields: [unitKerjaId], references: [id], onDelete: Restrict)

  title       String             @db.VarChar(255)
  status      WorkingPaperStatus @default(DRAFT)

  submittedAt DateTime?
  submittedBy String?
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?            @db.Text
  approvedAt  DateTime?
  approvedBy  String?

  createdBy   String?
  updatedBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  riskEntries RiskEntry[]

  /// Satu UnitKerja hanya boleh punya 1 kertas kerja per program
  @@unique([programId, unitKerjaId])
  @@index([programId])
  @@index([unitKerjaId])
  @@index([status])
  @@map("working_papers")
}

/// Identifikasi risiko individual dalam kertas kerja.
/// Setiap entry tahu framework & context-nya via programFrameworkContextId.
model RiskEntry {
  id                        String                  @id @default(cuid())
  workingPaperId            String
  workingPaper              WorkingPaper            @relation(fields: [workingPaperId], references: [id], onDelete: Cascade)
  programFrameworkContextId String
  programFrameworkContext   ProgramFrameworkContext @relation(fields: [programFrameworkContextId], references: [id], onDelete: Restrict)

  assetId                   String?
  asset                     Asset?                  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  businessProcessId         String?
  businessProcess           BusinessProcess?        @relation(fields: [businessProcessId], references: [id], onDelete: SetNull)

  code                      String                  @db.VarChar(50)
  name                      String                  @db.VarChar(500)
  description               String?                 @db.Text
  riskCategoryId            String?
  riskCategory              RiskCategory?           @relation(fields: [riskCategoryId], references: [id], onDelete: SetNull)
  order                     Int                     @default(0)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  inherentAssessment        RiskAssessment?         @relation("InherentAssessment")
  controls                  RiskControl[]
  residualAssessment        RiskAssessment?         @relation("ResidualAssessment")
  treatmentPlans            RiskTreatmentPlan[]

  @@index([workingPaperId])
  @@index([programFrameworkContextId])
  @@index([assetId])
  @@index([businessProcessId])
  @@map("risk_entries")
}

/// Penilaian risiko (inherent atau residual).
model RiskAssessment {
  id              String         @id @default(cuid())

  inherentEntryId String?        @unique
  inherentEntry   RiskEntry?     @relation("InherentAssessment", fields: [inherentEntryId], references: [id], onDelete: Cascade)
  residualEntryId String?        @unique
  residualEntry   RiskEntry?     @relation("ResidualAssessment", fields: [residualEntryId], references: [id], onDelete: Cascade)

  type            AssessmentType

  finalScore      Int?
  riskLevelId     String?
  riskLevel       RiskLevel?     @relation(fields: [riskLevelId], references: [id], onDelete: SetNull)
  notes           String?        @db.Text

  assessedAt      DateTime       @default(now())
  assessedBy      String?

  areaScores      AreaScore[]

  @@index([riskLevelId])
  @@map("risk_assessments")
}

/// Skor per area dampak dalam satu penilaian.
/// Fleksibel untuk berbagai konfigurasi matrix di setiap context/framework.
model AreaScore {
  id              String         @id @default(cuid())
  assessmentId    String
  assessment      RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  impactAreaId    String
  impactArea      ImpactArea     @relation(fields: [impactAreaId], references: [id], onDelete: Restrict)

  likelihoodLevel         Int
  impactLevel             Int
  likelihoodDescription   String? @db.Text
  impactDescription       String? @db.Text

  matrixCellId    String?
  matrixCell      MatrixCell?    @relation(fields: [matrixCellId], references: [id], onDelete: SetNull)
  score           Int

  @@unique([assessmentId, impactAreaId])
  @@index([assessmentId])
  @@map("area_scores")
}

/// Pengendalian yang sudah ada sebelum treatment.
model RiskControl {
  id            String               @id @default(cuid())
  riskEntryId   String
  riskEntry     RiskEntry            @relation(fields: [riskEntryId], references: [id], onDelete: Cascade)

  name          String               @db.VarChar(500)
  description   String?              @db.Text
  effectiveness ControlEffectiveness

  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([riskEntryId])
  @@map("risk_controls")
}

/// Rencana penanganan untuk risiko yang melampaui risk appetite.
/// Setiap rencana terkait dengan satu area dampak yang dinilai.
model RiskTreatmentPlan {
  id                String              @id @default(cuid())
  riskEntryId       String
  riskEntry         RiskEntry           @relation(fields: [riskEntryId], references: [id], onDelete: Cascade)
  impactAreaId      String?
  impactArea        ImpactArea?         @relation(fields: [impactAreaId], references: [id], onDelete: SetNull)
  treatmentOptionId String?
  treatmentOption   TreatmentOption?    @relation(fields: [treatmentOptionId], references: [id], onDelete: SetNull)

  description       String?             @db.Text
  targetDate        DateTime?
  picUserId         String?

  status            TreatmentStatus     @default(PLANNED)
  needsKomiteReview Boolean             @default(false)
  completedAt       DateTime?
  progressNote      String?             @db.Text
  evidenceUrl       String?             @db.VarChar(1000)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  monitoringLogs    TreatmentMonitoring[]

  @@index([riskEntryId])
  @@index([impactAreaId])
  @@index([status])
  @@map("risk_treatment_plans")
}

/// Log monitoring realisasi rencana penanganan per periode.
model TreatmentMonitoring {
  id          String            @id @default(cuid())
  planId      String
  plan        RiskTreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  period      String            @db.VarChar(50)
  progress    Int
  note        String?           @db.Text
  evidenceUrl String?           @db.VarChar(1000)
  reportedBy  String?
  reportedAt  DateTime          @default(now())

  @@index([planId])
  @@map("treatment_monitoring")
}

// =============================================================================
// SYSTEM MODELS
// =============================================================================

model SystemConfig {
  key         String         @id @db.VarChar(100)
  value       String         @db.VarChar(1000)
  dataType    ConfigDataType @default(STRING)
  group       String         @db.VarChar(50)
  label       String         @db.VarChar(255)
  description String?        @db.Text
  isEditable  Boolean        @default(true)
  updatedAt   DateTime       @updatedAt
  updatedBy   String?

  @@index([group])
  @@map("system_configs")
}

// =============================================================================
// ENUMS
// =============================================================================

enum ConfigDataType {
  STRING
  INTEGER
  BOOLEAN
}

enum RoleName {
  USER
  ADMINISTRATOR
  KOMITE_PUSAT
  PENGELOLA_RISIKO_UKER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProcessStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ContextType {
  ASSET
  PROCESS
}

enum RiskProgramStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ProgramFrameworkStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RiskContextStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkingPaperStatus {
  DRAFT
  SUBMITTED
  REVISION
  APPROVED
  LOCKED
}

enum AssessmentType {
  INHERENT
  RESIDUAL
}

enum ControlEffectiveness {
  ADEQUATE
  PARTIAL
  INADEQUATE
}

enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  SUBMITTED_FOR_REVIEW
  VERIFIED
}
